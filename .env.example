# PostgreSQL
PG_HOST=postgres
PG_PORT=5432
PG_USER=jobqueue
PG_PASSWORD=jobqueue_secret
PG_DATABASE=jobqueue

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API Server
API_PORT=4000

# Worker — comma-separated queue names
QUEUES=email,video-processing,notifications

# Worker — concurrency per queue
CONCURRENCY_email=5
CONCURRENCY_video-processing=2
CONCURRENCY_notifications=10

# Worker — max retries per job type
MAX_RETRIES_send-email=3
MAX_RETRIES_resize-image=3
MAX_RETRIES_generate-report=2

# Worker — job timeout per job type (ms)
JOB_TIMEOUT_send-email=30000
JOB_TIMEOUT_resize-image=60000
JOB_TIMEOUT_generate-report=120000

# Dashboard (Vite)
VITE_API_URL=http://localhost:4000
VITE_POLL_INTERVAL=5000
